// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  IMAGE
  VIDEO
}

model Category {
  id       String     @id @default(cuid())
  name     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  coupons  Coupon[]

  @@index([parentId])
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String?          @unique
  description    String?
  price          Decimal
  promoPrice     Decimal?
  cost           Decimal?
  images         String
  videos         String           @default("[]")
  sizes          String
  seoTitle       String?
  seoDescription String?
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  media          ProductMedia[]
  coupons        Coupon[]
  isFeatured     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([categoryId])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color      String
  size       String
  sku        String?
  stock      Int      @default(0)
  price      Decimal?
  promoPrice Decimal?
  cost       Decimal?
  media      String   @default("[]")
  mediaItems ProductMedia[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
}

model ProductMedia {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  type       MediaType
  url        String
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([productId, sortOrder])
  @@index([variantId, sortOrder])
}

model Order {
  id              String   @id @default(cuid())
  shortId         String   @unique
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  customerDocument String?
  customerAddress String?
  couponCode      String?
  discount        Decimal  @default(0)
  subtotal        Decimal  @default(0)
  items           String
  total           Decimal
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  @@index([customerId])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  document    String?
  address     String?
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Coupon {
  id                String     @id @default(cuid())
  code              String     @unique
  discountType      String
  value             Decimal    @default(0)
  appliesTo         String     @default("STORE")
  categoryId        String?
  category          Category?  @relation(fields: [categoryId], references: [id])
  productId         String?
  product           Product?   @relation(fields: [productId], references: [id])
  usageLimit        Int?
  perCustomerLimit  Int?
  firstPurchaseOnly Boolean    @default(false)
  startsAt          DateTime?
  endsAt            DateTime?
  minCartValue      Decimal?
  maxDiscount       Decimal?
  includeShipping   Boolean    @default(false)
  combinesWithPromos Boolean   @default(true)
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([categoryId])
  @@index([productId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  productId String?
  metadata  String?
  createdAt DateTime @default(now())
}

model AdminUser {
  id       String @id @default(cuid())
  email    String @unique
  password String?
}

model SiteConfig {
  id               String @id @default("singleton")
  topBannerText    String @default("FRETE GRATIS EM PALMAS - TO / ENTREGA LOCAL")
  isBannerVisible  Boolean @default(true)
  whatsappNumber   String @default("5500000000000")
  heroImage1       String @default("/post01.jpg")
  heroImage2       String @default("/post01.jpg")
  heroImage3       String @default("/post01.jpg")
  updatedAt        DateTime @updatedAt
}
